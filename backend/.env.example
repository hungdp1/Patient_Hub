# Database
# For local: "postgresql://user:password@localhost:5432/patient_hub"
# For production (e.g. Supabase, Neon): "postgresql://username:password@cloud-host.com:5432/dbname"
DATABASE_URL="postgresql://user:password@localhost:5432/patient_hub"

# Server
PORT=5000
NODE_ENV=development # Change to 'production' for deployment

# JWT
# In production, make sure this is a long, random, and secure string
JWT_SECRET="your-secret-key-here"
JWT_EXPIRATION="7d"

# Frontend URL
# For local: "http://localhost:3000" or "http://localhost:5173"
# For production: "https://your-frontend-domain.vercel.app"
FRONTEND_URL="http://localhost:3000"

# Google Gemini API (for AI assistant features)
GEMINI_API_KEY="your-gemini-api-key"
